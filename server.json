{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.sypherin/altronis-mcp",
  "description": "Ask the Altronis AI advisor: grant-matched AI plans, SG AI events, news, ecosystem data. Read-only.",
  "repository": {
    "url": "https://github.com/sypherin/altronis-mcp",
    "source": "github"
  },
  "websiteUrl": "https://altronis.sg",
  "version": "0.1.1",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "@altronis/altronis-mcp",
      "version": "0.1.1",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "description": "Base URL of the Altronis site (default: https://altronis.sg)",
          "isRequired": false,
          "format": "string",
          "isSecret": false,
          "name": "ALTRONIS_BASE_URL"
        },
        {
          "description": "HTTP timeout in milliseconds (default: 30000)",
          "isRequired": false,
          "format": "number",
          "isSecret": false,
          "name": "ALTRONIS_TIMEOUT_MS"
        }
      ]
    }
  ]
}
